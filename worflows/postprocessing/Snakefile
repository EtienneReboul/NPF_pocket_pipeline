"""
Snakefile_postprocess — Stages 6–13
=====================================
Run locally (Mac / workstation) after Boltz-2 has completed on the cluster.

  6.  ChimeraX    — energy minimization, CIF → PDB
  7.  PLIP         — protein–ligand interaction profiling via Docker
  8.  pliparser    — PLIP report → CSV + ChimeraX .cxc
  9.  Aggregate    — merge per-sample CSVs (one summary per protein × conformation)
  10. DSSP         — ChimeraX DSSP on raw Boltz-2 CIF (TM helix sanity check)
  11. tm_angle     — TM2/TM8 helix axis angle per sample
  12. collect_angles — merge per-sample angles (one CSV per protein × conformation)
  13. gmm_analysis — fit 3- and 6-component GMMs, compare by BIC

Prerequisites:
  - Snakefile_preprocess completed (stages 1–4)
  - submit_boltz2.sh completed (stage 5) — all prediction.done files exist
  - Transfer results/boltz/ from cluster back to local machine

Usage:
  snakemake -s Snakefile_postprocess --cores 10 --use-conda
"""

import json
from pathlib import Path

configfile: "config.yaml"
if Path("config.local.yaml").exists():
    configfile: "config.local.yaml"

# ── Directory shortcuts ────────────────────────────────────────────────────────
DIRS         = config["dirs"]
MSA_DIR      = Path(DIRS["msa"])
BOLTZ_OUT    = Path(DIRS["boltz_out"])
SANITIZED_DIR = Path(DIRS.get("sanitized", "results/sanitized"))
MIN_DIR      = Path(DIRS["minimized"])
PLIP_DIR     = Path(DIRS["plip"])
INTERPRO_DIR = Path(DIRS["interpro"])
DSSP_DIR     = Path(DIRS["dssp"])
TM_ANG_DIR   = Path(DIRS["tm_angles"])
GMM_DIR      = Path(DIRS["gmm"])
LOG_DIR      = Path(DIRS["logs"])

FASTA_DIR    = Path(DIRS["fasta"])

PLIP_CFG     = config["plip"]
VIZ_CFG      = config["visualization"]
TM_ANG_CFG   = config["tm_angle"]
GMM_CFG      = config["gmm"]
CHIMERAX_BIN = config["chimerax_bin"]

TOPO_SENTINEL = INTERPRO_DIR / "deeptmhmm_topology.done"
CONFORMATIONS = list(config["templates"]["conformations"].keys())

wildcard_constraints:
    protein      = r"[^/]+",
    conformation = r"[^/]+",
    sample_id    = r"[^/]+",


# ── Discover proteins and samples from Boltz-2 output on disk ─────────────────
# No checkpoint needed: all CIFs already exist.

def read_proteins(sentinel_path):
    """Read protein names from the MSA sentinel file."""
    p = Path(sentinel_path)
    if p.exists():
        return [line.strip() for line in p.read_text().splitlines() if line.strip()]
    return []

MSA_SENTINEL = MSA_DIR / "msa.done"
PROTEINS = read_proteins(MSA_SENTINEL)

if not PROTEINS:
    raise ValueError(
        f"\n Cannot read protein list from {MSA_SENTINEL}.\n"
        " Run Snakefile_preprocess first.\n"
    )


def discover_cifs(protein, conformation):
    """
    Glob CIF files produced by Boltz-2 for one protein × conformation.
    Boltz-2 nests predictions under a content-hashed subdirectory, e.g.
      boltz_out/boltz_results_target/predictions/target/target_model_0.cif
    so we glob from boltz_out/ with a recursive pattern.
    Returns a sorted list of Path objects.
    """
    boltz_root = BOLTZ_OUT / protein / conformation / "boltz_out"
    return sorted(boltz_root.glob("**/predictions/**/*.cif")) if boltz_root.exists() else []


def discover_sample_ids(protein, conformation):
    """Return list of sample_id strings (CIF stems) for one run."""
    return [c.stem for c in discover_cifs(protein, conformation)]


def cif_path_for_sample(protein, conformation, sample_id):
    """Return the actual CIF path for a given sample_id."""
    for c in discover_cifs(protein, conformation):
        if c.stem == sample_id:
            return str(c)
    raise FileNotFoundError(
        f"CIF not found for {protein}/{conformation}/{sample_id}. "
        "Has Boltz-2 completed? Check prediction.done."
    )


# ── Build the complete target list upfront ────────────────────────────────────
# Since all Boltz-2 outputs exist on disk, we can enumerate everything now.

TARGETS = []     # final aggregate CSV + per-sample CXC scripts
ALL_JOBS = {}    # (protein, conformation) → [sample_id, ...]

for protein in PROTEINS:
    for conformation in CONFORMATIONS:
        done_file = BOLTZ_OUT / protein / conformation / "prediction.done"
        if not done_file.exists():
            continue   # skip proteins that haven't been predicted yet

        sample_ids = discover_sample_ids(protein, conformation)
        if not sample_ids:
            print(f"[postprocess] WARNING: no CIFs for {protein}/{conformation} — skipping")
            continue

        ALL_JOBS[(protein, conformation)] = sample_ids
        # aggregate CSV (one per protein × conformation)
        TARGETS.append(
            str(PLIP_DIR / protein / conformation / "summary.csv")
        )
        # per-conformation angle CSV (stages 10–12)
        TARGETS.append(
            str(TM_ANG_DIR / protein / conformation / "angles.csv")
        )
        # ChimeraX visualization scripts (one per sample)
        for sid in sample_ids:
            TARGETS.append(
                str(PLIP_DIR / protein / conformation / sid
                    / "model_minimized_report" / "interaction.cxc")
            )

# GMM report is global across all protein × conformation combos (stage 13)
if ALL_JOBS:
    TARGETS.append(str(GMM_DIR / "gmm_report.json"))

print(f"[postprocess] {len(ALL_JOBS)} protein × conformation combos, {len(TARGETS)} targets.")


# ─────────────────────────────────────────────────────────────────────────────
# STAGE 6a: Sanitize CIF — split protein/ligand, normalize ligand with RDKit
# ─────────────────────────────────────────────────────────────────────────────

rule sanitize_cif:
    input:
        cif = lambda wc: cif_path_for_sample(wc.protein, wc.conformation, wc.sample_id),
    output:
        pdb = str(SANITIZED_DIR / "{protein}" / "{conformation}" / "{sample_id}" / "model_sanitized.pdb"),
    log:
        str(LOG_DIR / "sanitize" / "{protein}" / "{conformation}" / "{sample_id}.log"),
    conda:
        "../../envs/sanitize.yaml"
    shell:
        """
        python scripts/sanitize_cif.py \\
            --input  {input.cif} \\
            --output {output.pdb} \\
        > {log} 2>&1
        """


# ─────────────────────────────────────────────────────────────────────────────
# STAGE 6b: ChimeraX minimization (on sanitized PDB)
# ─────────────────────────────────────────────────────────────────────────────

rule minimize_cif:
    input:
        pdb = str(SANITIZED_DIR / "{protein}" / "{conformation}" / "{sample_id}" / "model_sanitized.pdb"),
    output:
        pdb = str(MIN_DIR / "{protein}" / "{conformation}" / "{sample_id}" / "model_minimized.pdb"),
    params:
        chimerax = CHIMERAX_BIN,
    log:
        str(LOG_DIR / "minimize" / "{protein}" / "{conformation}" / "{sample_id}.log"),
    shell:
        """
        mkdir -p $(dirname {output.pdb})
        {params.chimerax} --nogui \\
            --script "scripts/minimize_cif.py {input.pdb} {output.pdb}" \\
        > {log} 2>&1
        """


# ─────────────────────────────────────────────────────────────────────────────
# STAGE 7: PLIP via Docker
# ─────────────────────────────────────────────────────────────────────────────

rule run_plip:
    input:
        pdb = str(MIN_DIR / "{protein}" / "{conformation}" / "{sample_id}" / "model_minimized.pdb"),
    output:
        report = str(
            PLIP_DIR / "{protein}" / "{conformation}" / "{sample_id}"
            / "model_minimized_report" / "model_minimized_report.txt"
        ),
    params:
        image         = PLIP_CFG["image"],
        docker_memory = PLIP_CFG["docker_memory"],
        platform_flag = (
            f"--platform {PLIP_CFG['docker_platform']}"
            if PLIP_CFG.get("docker_platform") else ""
        ),
        # apo  → intra-chain profiling (no ligand present)
        # holo → auto-detect ligand interactions (no --chains needed)
        plip_mode     = lambda wc: "--intra A" if "_apo" in wc.conformation else "",
        report_dir    = str(
            PLIP_DIR / "{protein}" / "{conformation}" / "{sample_id}"
            / "model_minimized_report"
        ),
    log:
        str(LOG_DIR / "plip" / "{protein}" / "{conformation}" / "{sample_id}.log"),
    shell:
        """
        mkdir -p {params.report_dir}
        docker run --rm \\
            --memory={params.docker_memory} \\
            {params.platform_flag} \\
            -v $(pwd):/work -w /work \\
            {params.image} \\
            -f {input.pdb} \\
            -t \\
            {params.plip_mode} \\
            -o {params.report_dir} \\
        > {log} 2>&1
        """


# ─────────────────────────────────────────────────────────────────────────────
# STAGE 8: pliparser — PLIP report → CSV + CXC
# ─────────────────────────────────────────────────────────────────────────────

rule plip_to_csv:
    input:
        report = str(
            PLIP_DIR / "{protein}" / "{conformation}" / "{sample_id}"
            / "model_minimized_report" / "model_minimized_report.txt"
        ),
    output:
        summary = str(
            PLIP_DIR / "{protein}" / "{conformation}" / "{sample_id}"
            / "model_minimized_report" / "csv" / "summary.csv"
        ),
    params:
        out_dir = str(
            PLIP_DIR / "{protein}" / "{conformation}" / "{sample_id}"
            / "model_minimized_report" / "csv"
        ),
    log:
        str(LOG_DIR / "pliparser" / "{protein}" / "{conformation}" / "{sample_id}_csv.log"),
    conda:
        "../../envs/pliparser.yaml"
    shell:
        """
        mkdir -p {params.out_dir}
        pliparser plip2csv \\
            --input  {input.report} \\
            --output {params.out_dir}/ \\
        > {log} 2>&1
        """


rule csv_to_cxc:
    input:
        csv_summary = str(
            PLIP_DIR / "{protein}" / "{conformation}" / "{sample_id}"
            / "model_minimized_report" / "csv" / "summary.csv"
        ),
        pdb = str(
            MIN_DIR / "{protein}" / "{conformation}" / "{sample_id}" / "model_minimized.pdb"
        ),
    output:
        cxc    = str(
            PLIP_DIR / "{protein}" / "{conformation}" / "{sample_id}"
            / "model_minimized_report" / "interaction.cxc"
        ),
        config_json = str(
            PLIP_DIR / "{protein}" / "{conformation}" / "{sample_id}"
            / "model_minimized_report" / "cxc-config.json"
        ),
    params:
        csv_dir        = str(
            PLIP_DIR / "{protein}" / "{conformation}" / "{sample_id}"
            / "model_minimized_report" / "csv"
        ),
        receptor_chain = "A",
        ligand_chain   = "A",               # ligand is a small molecule within chain A
        transparency   = VIZ_CFG["transparency"],
        receptor_color = VIZ_CFG["receptor_color"],
        ligand_color   = VIZ_CFG["ligand_color"],
        # holo → --issmalmol (nitrate is a small molecule in chain A)
        # apo  → no flag (intra-chain profiling, no small molecule)
        issmalmol_flag = lambda wc: "--issmalmol" if "_holo" in wc.conformation else "",
    log:
        str(LOG_DIR / "pliparser" / "{protein}" / "{conformation}" / "{sample_id}_cxc.log"),
    conda:
        "../../envs/pliparser.yaml"
    shell:
        """
        python scripts/make_cxc_config.py \\
            --pdb             {input.pdb} \\
            --output          {output.config_json} \\
            --receptor-chain  {params.receptor_chain} \\
            --ligand-chain    {params.ligand_chain} \\
            --transparency    {params.transparency} \\
            --receptor-color  {params.receptor_color} \\
            --ligand-color    {params.ligand_color} \\
            {params.issmalmol_flag} \\
        > {log} 2>&1

        pliparser csv2cxc \\
            --input  {params.csv_dir} \\
            --output {output.cxc} \\
            --config {output.config_json} \\
        >> {log} 2>&1
        """


# ─────────────────────────────────────────────────────────────────────────────
# STAGE 9: Aggregate per protein × conformation
# ─────────────────────────────────────────────────────────────────────────────

def summaries_for_protein_conformation(wildcards):
    """Return all per-sample summary CSVs for one protein × conformation."""
    sample_ids = ALL_JOBS.get((wildcards.protein, wildcards.conformation), [])
    return [
        str(
            PLIP_DIR / wildcards.protein / wildcards.conformation
            / sid / "model_minimized_report" / "csv" / "summary.csv"
        )
        for sid in sample_ids
    ]


rule aggregate_plip:
    input:
        csvs = summaries_for_protein_conformation,
    output:
        str(PLIP_DIR / "{protein}" / "{conformation}" / "summary.csv"),
    log:
        str(LOG_DIR / "aggregate" / "{protein}" / "{conformation}.log"),
    conda:
        "../../envs/aggregate.yaml"
    shell:
        """
        python scripts/aggregate_plip_summary.py \\
            --output {output} \\
            {input.csvs} \\
        > {log} 2>&1
        """


# ─────────────────────────────────────────────────────────────────────────────
# STAGES 10–13 — Conformational angle classification via GMM
# ─────────────────────────────────────────────────────────────────────────────

# ── Stage 2b (prerequisite): TM topology via DeepTMHMM ────────────────────────
# Submits all NPF sequences to DeepTMHMM (BioLib cloud). If the GFF3 output
# already exists the cloud call is skipped (cached run). The script aborts
# with a non-zero exit code — halting the pipeline — if any protein does not
# have exactly 12 predicted TM helices.

rule run_deeptmhmm_topology:
    input:
        fasta    = str(FASTA_DIR / "npf_arabidopsis.fasta"),
        msa_done = str(MSA_SENTINEL),
    output:
        gff3     = str(INTERPRO_DIR / "deeptmhmm_TMRs.gff3"),
        topology = str(INTERPRO_DIR / "tm_topology_summary.json"),
        sentinel = str(TOPO_SENTINEL),
    log:
        str(LOG_DIR / "deeptmhmm_topology.log"),
    shell:
        """
        python scripts/run_deeptmhmm_topology.py \\
            --fasta       {input.fasta} \\
            --gff3        {output.gff3} \\
            --topology    {output.topology} \\
            --sentinel    {output.sentinel} \\
            --expected-tm 12 \\
        > {log} 2>&1
        """


# ── Stage 10: ChimeraX DSSP on raw Boltz-2 CIF ────────────────────────────────

rule run_dssp:
    input:
        cif = lambda wc: cif_path_for_sample(wc.protein, wc.conformation, wc.sample_id),
    output:
        dssp = str(DSSP_DIR / "{protein}" / "{conformation}" / "{sample_id}" / "dssp.json"),
    params:
        chimerax = CHIMERAX_BIN,
    log:
        str(LOG_DIR / "dssp" / "{protein}" / "{conformation}" / "{sample_id}.log"),
    shell:
        """
        mkdir -p $(dirname {output.dssp})
        {params.chimerax} --nogui \\
            --script "scripts/chimerax_dssp.py {input.cif} {output.dssp}" \\
        > {log} 2>&1
        """


# ── Stage 11: TM2/TM8 angle per sample ────────────────────────────────────────

rule compute_tm_angle:
    input:
        cif      = lambda wc: cif_path_for_sample(wc.protein, wc.conformation, wc.sample_id),
        dssp     = str(DSSP_DIR / "{protein}" / "{conformation}" / "{sample_id}" / "dssp.json"),
        topology = str(INTERPRO_DIR / "tm_topology_summary.json"),
    output:
        angle_csv = str(TM_ANG_DIR / "{protein}" / "{conformation}" / "{sample_id}" / "angle.csv"),
    params:
        min_helix_frac = TM_ANG_CFG["min_helix_frac"],
    log:
        str(LOG_DIR / "tm_angle" / "{protein}" / "{conformation}" / "{sample_id}.log"),
    conda:
        "../../envs/tm_analysis.yaml"
    shell:
        """
        python scripts/compute_tm_angle.py \\
            --cif           {input.cif} \\
            --dssp          {input.dssp} \\
            --topology      {input.topology} \\
            --protein       {wildcards.protein} \\
            --conformation  {wildcards.conformation} \\
            --sample-id     {wildcards.sample_id} \\
            --output        {output.angle_csv} \\
            --min-helix-frac {params.min_helix_frac} \\
        > {log} 2>&1
        """


# ── Stage 12: Collect per-sample angles for one protein × conformation ────────

def angle_csvs_for_protein_conformation(wildcards):
    sample_ids = ALL_JOBS.get((wildcards.protein, wildcards.conformation), [])
    return [
        str(TM_ANG_DIR / wildcards.protein / wildcards.conformation / sid / "angle.csv")
        for sid in sample_ids
    ]


rule collect_tm_angles:
    input:
        csvs = angle_csvs_for_protein_conformation,
    output:
        str(TM_ANG_DIR / "{protein}" / "{conformation}" / "angles.csv"),
    log:
        str(LOG_DIR / "collect_angles" / "{protein}" / "{conformation}.log"),
    conda:
        "../../envs/aggregate.yaml"
    shell:
        """
        python scripts/collect_angles.py --output {output} {input.csvs} > {log} 2>&1
        """


# ── Stage 13: Fit GMM-3 and GMM-6 + BIC comparison (global) ──────────────────

def all_angle_csv_inputs(wildcards):
    """Return all per-conformation angle CSVs (one per protein × conformation)."""
    return [
        str(TM_ANG_DIR / protein / conformation / "angles.csv")
        for protein, conformation in ALL_JOBS
    ]


rule gmm_analysis:
    input:
        csvs = all_angle_csv_inputs,
    output:
        sentinel = str(GMM_DIR / "gmm.done"),
        report   = str(GMM_DIR / "gmm_report.json"),
    params:
        out_dir = str(GMM_DIR),
        n_init  = GMM_CFG["n_init"],
    log:
        str(LOG_DIR / "gmm_analysis.log"),
    conda:
        "../../envs/tm_analysis.yaml"
    shell:
        """
        python scripts/gmm_conformation.py \\
            --input      {input.csvs} \\
            --output-dir {params.out_dir} \\
            --sentinel   {output.sentinel} \\
            --n-init     {params.n_init} \\
        > {log} 2>&1
        """


# ─────────────────────────────────────────────────────────────────────────────
# RULE ALL — postprocess targets
# ─────────────────────────────────────────────────────────────────────────────

rule all:
    default_target: True
    input:
        TARGETS