"""
Snakefile_preprocess — Stages 1–4
=================================
Run locally (Mac / workstation). Prepares all inputs needed for Boltz-2.

  1. MSA           — UniProt → ColabFold MSA per protein
  2. InterProScan  — EMBL-EBI CDD → binding-site residues
  3. Templates     — RCSB mmCIF download per conformation
  4. Boltz-2 input — YAML generation per protein × conformation

Interface to processing stage:
  data/boltz_inputs/{protein}/{conformation}/target.yaml  (one per combo)
  data/msa/msa.done                                       (protein name list)

Usage:
  snakemake -s Snakefile_preprocess --cores 4
"""

import json
from pathlib import Path


configfile: "config.yaml"


if Path("config.local.yaml").exists():

    configfile: "config.local.yaml"


# Validate email
_email = config.get("interproscan", {}).get("email", "")
if _email in ("", "your@email.com", "firstname.lastname@institution.fr"):
    raise ValueError(
        "\n"
        "═══════════════════════════════════════════════════════════\n"
        " Missing personal configuration!\n"
        " cp config.local.yaml.example config.local.yaml\n"
        " then set your email in config.local.yaml\n"
        "═══════════════════════════════════════════════════════════\n"
    )

# ── Directory shortcuts ────────────────────────────────────────────────────────
DIRS = config["dirs"]
FASTA_DIR = Path(DIRS["fasta"])
MSA_DIR = Path(DIRS["msa"])
INTERPRO_DIR = Path(DIRS["interpro"])
TMPL_DIR = Path(DIRS["templates"])
LOG_DIR = Path(DIRS["logs"])
BOLTZ_CFG = config["boltz"]
CONFORMATIONS = list(config["templates"]["conformations"].keys())

# Synthetic-template runs write inputs to a separate dir to avoid overwriting.
_synth_cfg = config.get("templates", {}).get("synthetic", {})
_run_suffix = ("_" + _synth_cfg["run_label"]) if _synth_cfg.get("enabled") else ""
BOLTZ_IN_DIR = Path(DIRS["boltz_in"] + _run_suffix)

# Stripped synthetic templates land here (protein-only CIFs safe for Boltz-2 template validation)
SYNTH_TMPL_DIR = Path("data/synthetic_templates")
SYNTH_TMPL_SENTINEL = str(SYNTH_TMPL_DIR / "stripped.done")

MSA_SENTINEL = MSA_DIR / "msa.done"
IPRO_SENTINEL = INTERPRO_DIR / "interproscan.done"
TMPL_SENTINEL = TMPL_DIR / "templates.done"


def read_proteins(sentinel_path):
    p = Path(sentinel_path)
    if p.exists():
        return [line.strip() for line in p.read_text().splitlines() if line.strip()]
    return []


# ─────────────────────────────────────────────────────────────────────────────
# STAGE 1: MSA (checkpoint — discovers protein list)
# ─────────────────────────────────────────────────────────────────────────────


checkpoint msa_checkpoint:
    output:
        sentinel=str(MSA_SENTINEL),
    log:
        str(LOG_DIR / "msa.log"),
    params:
        fasta_dir=str(FASTA_DIR),
        a3m_dir=str(MSA_DIR / "a3m"),
        pdb_dir=str(MSA_DIR / "pdb"),
        sh_dir=str(MSA_DIR / "sh"),
        query=config["uniprot"]["query"],
        size=config["uniprot"]["size"],
        delay=config["colabfold"]["delay"],
        retries=config["colabfold"]["max_retries"],
        poll_int=config["colabfold"]["poll_interval"],
        poll_timeout=config["colabfold"]["poll_timeout"],
    shell:
        """
        python scripts/run_msa.py \\
        --fasta-dir {params.fasta_dir} \\
        --a3m-dir {params.a3m_dir} \\
        --pdb-dir {params.pdb_dir} \\
        --sh-dir {params.sh_dir} \\
        --sentinel {output.sentinel} \\
        --query '{params.query}' \\
        --size {params.size} \\
        --delay {params.delay} \\
        --retries {params.retries} \\
        --poll-interval {params.poll_int} \\
        --poll-timeout {params.poll_timeout} \\
        >{log} 2>&1
        """


# ─────────────────────────────────────────────────────────────────────────────
# STAGE 2: InterProScan
# ─────────────────────────────────────────────────────────────────────────────


rule run_interproscan:
    input:
        fasta=str(FASTA_DIR / "npf_arabidopsis.fasta"),
        msa_done=str(MSA_SENTINEL),
    output:
        sentinel=str(IPRO_SENTINEL),
        summary=str(INTERPRO_DIR / "cdd_summary.json"),
    log:
        str(LOG_DIR / "interproscan.log"),
    params:
        out_dir=str(INTERPRO_DIR),
        email=config["interproscan"]["email"],
        accessions=" ".join(config["interproscan"]["cdd_accessions"]),
        poll_int=config["interproscan"]["poll_interval"],
        poll_timeout=config["interproscan"]["poll_timeout"],
    shell:
        """
        python scripts/run_interproscan.py \\
        --fasta {input.fasta} \\
        --out-dir {params.out_dir} \\
        --email {params.email} \\
        --accessions {params.accessions} \\
        --sentinel {output.sentinel} \\
        --poll-interval {params.poll_int} \\
        --poll-timeout {params.poll_timeout} \\
        >{log} 2>&1
        """


# ─────────────────────────────────────────────────────────────────────────────
# STAGE 3a: Strip synthetic template ligands (only when synthetic run enabled)
# ─────────────────────────────────────────────────────────────────────────────


if _synth_cfg.get("enabled"):
    rule strip_synthetic_templates:
        output:
            sentinel=SYNTH_TMPL_SENTINEL,
        log:
            str(LOG_DIR / "strip_synthetic_templates.log"),
        conda:
            "../../envs/preprocessing.yaml"
        params:
            out_dir=str(SYNTH_TMPL_DIR),
            chimerax=config.get("chimerax_bin", "ChimeraX"),
        shell:
            """
            python scripts/prepare_synthetic_templates.py \\
            --config config.yaml \\
            --out-dir {params.out_dir} \\
            --chimerax-bin {params.chimerax} \\
            --sentinel {output.sentinel} \\
            >{log} 2>&1
            """


# ─────────────────────────────────────────────────────────────────────────────
# STAGE 3b: Template download
# ─────────────────────────────────────────────────────────────────────────────


rule download_templates:
    output:
        sentinel=str(TMPL_SENTINEL),
    log:
        str(LOG_DIR / "download_templates.log"),
    conda:
        "../../envs/preprocessing.yaml"
    params:
        templates_root=str(TMPL_DIR),
    shell:
        """
        python scripts/download_templates.py \\
        --config config.yaml \\
        --templates-root {params.templates_root} \\
        --sentinel {output.sentinel} \\
        --prune \\
        >{log} 2>&1
        """


# ─────────────────────────────────────────────────────────────────────────────
# STAGE 4: Prepare Boltz-2 input YAML
# ─────────────────────────────────────────────────────────────────────────────


rule prepare_boltz_input:
    input:
        fasta=str(FASTA_DIR / "{protein}.fasta"),
        a3m=str(MSA_DIR / "a3m" / "{protein}.a3m"),
        cdd_summary=str(INTERPRO_DIR / "cdd_summary.json"),
        tmpl_done=str(TMPL_SENTINEL),
        **({} if not _synth_cfg.get("enabled") else
           {"synth_stripped": SYNTH_TMPL_SENTINEL}),
    output:
        yaml=str(BOLTZ_IN_DIR / "{protein}" / "{conformation}" / "target.yaml"),
    log:
        str(LOG_DIR / "boltz_input" / "{protein}" / "{conformation}.log"),
    conda:
        "../../envs/preprocessing.yaml"
    params:
        templates_dir=str(TMPL_DIR / "{conformation}"),
        ligand_smiles=BOLTZ_CFG["ligand_smiles"],
        ligand_entity_id=BOLTZ_CFG["ligand_entity_id"],
        protein_entity_id=BOLTZ_CFG["protein_entity_id"],
        pocket_max_distance=BOLTZ_CFG["pocket_max_distance"],
        pocket_force=str(BOLTZ_CFG["pocket_force"]).lower(),
        synth_tmpl_dir=str(SYNTH_TMPL_DIR) if _synth_cfg.get("enabled") else "",
    shell:
        """
        python scripts/make_boltz_input.py \\
        --fasta {input.fasta} \\
        --a3m {input.a3m} \\
        --cdd-summary {input.cdd_summary} \\
        --protein-name {wildcards.protein} \\
        --templates-dir {params.templates_dir} \\
        --conformation {wildcards.conformation} \\
        --output {output.yaml} \\
        --ligand-smiles '{params.ligand_smiles}' \\
        --ligand-entity-id {params.ligand_entity_id} \\
        --protein-entity-id {params.protein_entity_id} \\
        --pocket-max-distance {params.pocket_max_distance} \\
        --pocket-force {params.pocket_force} \\
        $([ -n "{params.synth_tmpl_dir}" ] && echo "--synthetic-templates-config config.yaml --synthetic-templates-dir {params.synth_tmpl_dir}") \\
        >{log} 2>&1
        """


# ─────────────────────────────────────────────────────────────────────────────
# RULE ALL — preprocess target
# ─────────────────────────────────────────────────────────────────────────────


def all_preprocess_targets(wildcards):
    """
    One target.yaml per protein × conformation.
    Protein list comes from the msa_checkpoint sentinel.
    """
    sentinel = checkpoints.msa_checkpoint.get().output.sentinel
    proteins = read_proteins(sentinel)
    return [
        str(BOLTZ_IN_DIR / protein / conformation / "target.yaml")
        for protein in proteins
        for conformation in CONFORMATIONS
    ]


rule all:
    default_target: True
    input:
        all_preprocess_targets,
